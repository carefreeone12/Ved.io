# ============================================================
# Ved.io Python Backend — Environment Variables
# ============================================================
# Copy this file: cp .env.example .env
# All vars can also be set in configs/config.yaml (YAML takes precedence)

# --- App ---
APP_NAME="Huobao Drama API"
APP_VERSION="1.0.0"
APP_DEBUG=true
APP_LANGUAGE=zh

# --- Server ---
SERVER_PORT=5678
SERVER_HOST=0.0.0.0
SERVER_CORS_ORIGINS=["http://localhost:3012","http://localhost:5678"]

# --- Database ---
# Type: sqlite | postgres | mysql
DATABASE_TYPE=sqlite
DATABASE_PATH=./data/drama_generator.db

# Postgres (used when DATABASE_TYPE=postgres)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=veduser
DATABASE_PASSWORD=vedpassword
DATABASE_NAME=vecio

# --- Storage ---
# Type: local | minio
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/storage
STORAGE_BASE_URL=http://localhost:5678/static

# MinIO (used when STORAGE_TYPE=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vedio
MINIO_SECURE=false

# --- AI Provider Defaults (can be overridden per-project in ai_service_configs table) ---
AI_DEFAULT_TEXT_PROVIDER=openai
AI_DEFAULT_IMAGE_PROVIDER=openai
AI_DEFAULT_VIDEO_PROVIDER=doubao

# --- Iterative Critic ---
CRITIC_SCORE_THRESHOLD=7.5
CRITIC_MAX_ITERATIONS=3

# --- Redis (for LLM cache / Celery, optional) ---
REDIS_URL=redis://localhost:6379/0
